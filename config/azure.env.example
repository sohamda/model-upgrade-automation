# Copy these values into GitHub repository or environment variables.
# Do not commit live credentials or tenant-specific secrets.

# OIDC identity contract
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# TG2 resource naming map placeholders
RESOURCE_GROUP=
FOUNDRY_ACCOUNT_NAME=
FOUNDRY_PROJECT_NAME=
ACA_ENVIRONMENT_NAME=
ACA_JOB_NAME=
STORAGE_ACCOUNT_NAME=
KEY_VAULT_NAME=

# Quality/safety live benchmark refresh (opt-in --live only; placeholders, not live values)
# Owned Foundry project endpoint the RedTeam scan is scope-locked to.
FOUNDRY_PROJECT_ENDPOINT=
# Judge/grader model deployment name for content-safety + red-team scoring.
JUDGE_MODEL=
# PRIMARY deterministic red-team block-judging classifier (Phase 2 Step 2.2,
# Council C11). When unset, the primary classifier signal is treated as
# unavailable (None) and combine_block_signals() fails closed rather than
# fabricating a pass. Placeholder only; no Content Safety resource is
# provisioned or called by this repository.
CONTENT_SAFETY_ENDPOINT=

# RunContext defaults
DEPLOYMENT_TYPE=DataZoneStandard
ALLOWED_REGIONS=swedencentral
RETIREMENT_HORIZON_DAYS=90
CANDIDATES_PER_RETIRING_MODEL=3
ENABLE_AUTO_PR=false

# Ownership and cleanup tags
AUTOMATION_OWNERSHIP_TAG=model-upgrade-automation
AUTOMATION_SCOPE_TAG=ephemeral
MANAGED_BY_TAG=model-upgrade-automation
AUTOMATION_CLEANUP_TAG=ephemeral
