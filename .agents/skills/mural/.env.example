# Copy to $XDG_CONFIG_HOME/hve-core/mural.default.env (or run `mural auth bootstrap` /
# `mural auth login`) and `chmod 0600` on POSIX. The runtime refuses to load this file
# if the mode includes group/other bits unless MURAL_ENV_FILE_RELAXED=1.
MURAL_CLIENT_ID=
MURAL_CLIENT_SECRET=

# Optional overrides (leave commented to use built-in defaults):
# MURAL_PROFILE=default
# MURAL_REDIRECT_URI=http://localhost:8765/callback
# MURAL_SCOPES=murals:read murals:write workspaces:read rooms:read tags:read tags:write

# Credential backend selection (env -> backend -> file lookup):
# MURAL_CREDENTIAL_BACKEND=auto
# Set to `file` to force the file backend for headless / CI use; `keyring` to require an OS keychain.
