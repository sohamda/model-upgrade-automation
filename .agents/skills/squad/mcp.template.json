// hve-squad MCP server template (JSONC: JSON with comments)
//
// Purpose
//   Reference snippet for consumers who want the squad's recommended
//   Model Context Protocol (MCP) servers wired into their workspace.
//
// Scope
//   This file is documentation only. The hve-squad APM package never
//   reads or writes the consumer's `.vscode/mcp.json`. The consumer
//   owns merge and override of every entry below.
//
// How to use
//   1. Open or create `.vscode/mcp.json` in your workspace.
//   2. Copy the entries from `inputs` and `servers` below into your file.
//   3. Merge with any servers you already have configured; do not
//      replace existing entries you depend on.
//   4. Reload VS Code so Copilot picks up the new servers.
//
// Which servers are in scope
//   Two official, Microsoft-maintained MCP servers apply to the squad's
//   current scope: `@azure-devops/mcp` for work-item, repository, and
//   pipeline access, and `@azure/mcp` for live Azure governance
//   discovery, deployed-resource inventory, and KQL troubleshooting. The
//   `github` and `azure-pricing` entries below are optional: `github`
//   backs the remote approval channel, and `azure-pricing` backs the
//   Squad Cost Manager's retail-price lookups. No official MCP exists for
//   draw.io, for the python `diagrams` library, or (at authoring time)
//   for Azure pricing, so each optional entry documents its non-MCP
//   fallback. See
//   `.github/instructions/squad/squad-mcp-capability.instructions.md`
//   for the capability-aware fallbacks and out-of-band options.
//
// Credentials
//   The Azure DevOps server uses VS Code's managed Entra OAuth via the
//   `inputs` mechanism below. No Personal Access Token, secret, or
//   API key is stored in this file. Never commit secrets to
//   `.vscode/mcp.json`; rely on `inputs` and the system credential
//   store instead.
{
  "inputs": [
    {
      "id": "ado_org",
      "type": "promptString",
      "description": "Azure DevOps organization name (for example, 'contoso')",
      "default": ""
    },
    {
      "id": "ado_tenant",
      "type": "promptString",
      "description": "Microsoft Entra tenant ID (required for multi-tenant scenarios)",
      "default": ""
    }
  ],
  "servers": {
    "ado": {
      // Official Microsoft Azure DevOps MCP server (npm: @azure-devops/mcp).
      // Authenticates with managed Entra OAuth via the `inputs` above;
      // no PAT is embedded in this template.
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "${input:ado_org}",
        "--tenant",
        "${input:ado_tenant}",
        "-d",
        "core",
        "work",
        "work-items",
        "search",
        "repositories",
        "pipelines"
      ]
    },
    "azure": {
      // Official Microsoft Azure MCP server (npm: @azure/mcp). Backs the
      // squad's live Azure governance discovery, deployed-resource
      // inventory, and KQL troubleshooting (the `azure-resource`
      // capability used by the Deployer, As-Built Author, and Azure
      // Diagnose roles). Authenticates with the Azure SDK
      // `DefaultAzureCredential` chain via `az login` (managed Entra
      // OAuth); no PAT, secret, or API key is stored in this template.
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ]
    },
    "github": {
      // Optional: official GitHub MCP server, used by the squad's
      // `github-issue` approval channel to open/assign approval issues
      // for unattended (VM) runs. Not required — an authenticated `gh`
      // CLI is a sufficient fallback, and absent both the squad uses an
      // in-chat approval. See
      // `.github/instructions/squad/squad-notifications.instructions.md`.
      // Provide a token via the GITHUB_PERSONAL_ACCESS_TOKEN env var
      // (repo + issues scope); never embed the token in this file.
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@github/github-mcp-server"
      ]
    },
    "azure-pricing": {
      // Optional: a community Azure pricing MCP server used by the Squad
      // Cost Manager for retail-price, reserved-instance, spot, and
      // orphaned-resource lookups. No official Microsoft-maintained Azure
      // pricing MCP exists at authoring time, so the squad recommends a
      // community server you choose to trust:
      //   Primary:     msftnadavbh/AzurePricingMCP (active; ~18 tools,
      //                including reserved-instance, spot, orphaned-
      //                resource, Databricks, GitHub, and PTU sizing).
      //
      // Packaging caveat: this server is packaged for Python (pip /
      // Docker / uvx), NOT npm, so the `npx` form the other entries use
      // does not apply here. The invocation is likely one of the forms
      // below; VERIFY THE EXACT STDIO COMMAND before use. The precise
      // invocation is unverified and tracked as WI-02, so the
      // command/args below are a labeled placeholder, not a runnable
      // value:
      //   uvx:    "command": "uvx",    "args": ["<pricing-mcp-dist>"]
      //   pipx:   "command": "pipx",   "args": ["run", "<pricing-mcp-dist>"]
      //   docker: "command": "docker", "args": ["run", "-i", "--rm", "<pricing-mcp-image>"]
      //
      // When this server is absent, the cost-manager falls back to the
      // anonymous Azure Retail Prices REST API
      // (https://prices.azure.com/api/retail/prices) via the Researcher
      // Subagent. See the `Azure-pricing` capability row in
      // `.github/instructions/squad/squad-mcp-capability.instructions.md`.
      // The Retail Prices REST fallback is anonymous and daily-updated
      // and needs no credential; the pricing MCP's admin-tier tools
      // (orphaned resources, spot history) require `az login` while its
      // core price tools do not.
      "type": "stdio",
      "command": "<verify-WI-02-exact-stdio-command>",
      "args": [
        "<verify-WI-02-exact-stdio-args>"
      ]
    }
  }
}
